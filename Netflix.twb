      <aliases enabled='yes' />
      <column aggregation='None' datatype='integer' name='[Avg Watch Time Minutes (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='1' formula='[avg_watch_time_minutes]' peg='0' size='10.5' />
      </column>
      <column caption='Churned users' datatype='integer' name='[Calculation_0093237637566466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [churned] = &quot;Yes&quot; THEN 1 ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Engagement Score' datatype='real' name='[Calculation_0093237638619139]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([avg_watch_time_minutes] * 0.4) + &#13;&#10;([watch_sessions_per_week] * 0.3) + &#13;&#10;([completion_rate] * 0.3)' />
      </column>
      <column caption='Customer Segment' datatype='string' name='[Calculation_0093237639143428]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0093237638619139] &gt; 70 THEN &quot;High Engagement&quot;&#13;&#10;ELSEIF [Calculation_0093237638619139] &gt; 40 THEN &quot;Medium Engagement&quot;&#13;&#10;ELSE &quot;Low Engagement&quot;&#13;&#10;END' />
      </column>
      <column caption='Recency Group' datatype='string' name='[Calculation_0093237639311365]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [days_since_last_login] &lt;= 7 THEN &quot;Active Recently&quot;&#13;&#10;ELSEIF [days_since_last_login] &lt;= 30 THEN &quot;At Risk&quot;&#13;&#10;ELSE &quot;Dormant&quot;&#13;&#10;END' />
      </column>
      <column caption='Revenue per User' datatype='real' name='[Calculation_0093237639446534]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[monthly_fee] * [account_age_months]' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_0700170090110979]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0093237637566466])/ COUNT([user_id])' />
      </column>
      <column caption='Engagement Group' datatype='string' name='[Calculation_0700170144837640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0093237638619139] &gt;= 80 THEN &quot;High&quot;&#13;&#10;ELSEIF [Calculation_0093237638619139] &gt;= 50 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Low&quot;&#13;&#10;END' />
      </column>
      <column datatype='string' name='[Country (group)]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal'>
        <calculation class='categorical-bin' column='[country]' new-bin='true'>
          <bin default-name='true' value='&quot;Australia&quot;'>
            <value>&quot;Australia&quot;</value>
          </bin>
          <bin default-name='true' value='&quot;Brazil&quot;'>
