    <worksheet name='Low engagement users have higher churn rates, while high engagement users contribute more churn due to larger volume.'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontname='Sitka Banner' fontsize='9'>&lt;Sheet Name&gt;</run>
